<style>

.thought-card{
    background:#fcfcff;
    border:3px solid #5c5c60;
    border-radius:22px;
    padding:40px;
    box-shadow:0 6px 18px rgba(0,0,0,.06);
}

.theme-badge{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    /* padding: 6px 12px; */
    border-radius: 999px;
    background: #f8f9fa;
    font-size: 1rem;
    font-weight: 700;
    color: #343a40;
}

.theme-badge::before{
    content:"";
    width:16px;
    height:16px;
    border-radius:50%;
}

/* only the dot colors */
.theme-productivity::before{ background:#6FC3D6; }
.theme-growth::before{ background:#8BCF9B; }
.theme-mindset::before{ background:#B69AE8; }
.theme-discipline::before{ background:#F6B26B; }
.theme-life::before{ background:#F5D76E; }
.theme-other::before{ background:#C8C8C8; }

.thought-date{
    margin-top:10px;
    color:#7c7c82;
    display:flex;
    gap:8px;
    align-items:center;
}

.header-actions{
    display:flex;
    gap:12px;
}

.btn-action{
    border:none;
    background:none;
    text-decoration:none;
    color:#5c5c60;
    font-weight:500;
}

.btn-edit:hover{
    color:#111;
}

.btn-delete{
    color:#d97c7c;
}

.btn-delete:hover{
    color:#ee4949;
}

.thought-content{
    margin:26px 0;
    font-size:1rem;
    line-height:2;
    white-space:pre-wrap;
    color:#343434;
}

.thought-meta{

    display:grid;
    grid-template-columns: repeat(3,1fr);
    gap:40px;
    margin:35px 0;
    padding-top:25px;
    border-top:1px solid #ECECEC;

}

.meta-title{
    font-size:.82rem;
    font-weight:600;
    color:#8d8d92;
    text-transform:uppercase;
    letter-spacing:.05em;
    margin-bottom:8px;
}

.meta-value{
    display:flex;
    align-items:center;
    gap:8px;
    color:#8d8d92;
    font-size:.95rem;
}

.meta-value i{
    color:#6c757d;
}

.meta-value a{
    color:#2f2f2f;
    text-decoration:none;
}

.meta-value a:hover{
    color:#16A085;
}

@media (max-width:768px){
    .thought-meta{
        grid-template-columns:1fr;
        gap:24px;
    }
}

.thought-divider{
    border: 0;
    border-top: 1px solid #ECECEC;
    margin: 2.5rem 0 1.2rem;
}

.reflection-footer{
    display: flex;
    justify-content: left;
    align-items: center;
    flex-wrap: wrap;
    gap: .55rem;
    font-size: .82rem;
    color: #9AA0A6;
    user-select: none;
}

.footer-separator{
    color: #D1D5DB;
}

</style>
<div class="thought-details-wrapper">

    <a href="/thoughts" class="back-link">
        <i class="bi bi-arrow-left"></i>
        Back
    </a>

    <div class="thought-card">

        <!-- Header -->
        <div class="thought-header">

            <div>

                <span class="theme-badge theme-<%= thought.theme.toLowerCase() %>">
                    <%= thought.theme %>
                </span>

                <div class="thought-date">
                    <i class="bi bi-clock-history"></i>
                    <%= thought.displayDate %>
                </div>

            </div>

            <div class="header-actions">

                <a href="/thoughts/edit/<%= thought._id %>"
                    class="btn-action btn-edit"    data-bs-toggle="tooltip" data-bs-placement="top" title="Edit">
                    <i class="bi bi-pencil"></i>
                </a>

                <form
                    action="/thoughts/<%= thought._id %>/delete"
                    method="POST"
                    class="deleteThoughtForm">

                    <button class="btn-action btn-delete"    data-bs-toggle="tooltip" data-bs-placement="top" title="Move to Trash">
                        <i class="bi bi-trash"></i>
                    </button>

                </form>

            </div>

        </div>

        <hr class="thought-divider">

        <!-- Reflection -->

        <div class="thought-content"><p class="content"><%= (thought.content || "").trim() %></p></div>

        <!-- Metadata -->

        <div class="thought-meta">

            <% if (thought.mood) { %>
            <div class="meta-card">
                <div class="meta-title">Mood</div>

                <div class="meta-value">
                    <% if (thought.mood === "motivated") { %>
                    <i class="bi bi-emoji-heart-eyes emoji"></i>
                    <% } %>

                    <% if (thought.mood === "neutral") { %>
                        <i class="bi bi-emoji-expressionless emoji"></i>
                    <% } %>

                    <% if (thought.mood === "confused") { %>
                        <i class="bi bi-emoji-tear emoji"></i>
                    <% } %>

                    <% if (thought.mood === "inspired") { %>
                        <i class="bi bi-emoji-laughing emoji"></i>
                    <% } %>

                    <% if (thought.mood === "overwhelmed") { %>
                        <i class="bi bi-emoji-dizzy emoji"></i>
                    <% } %>
                    <span>
                        <%= thought.mood.charAt(0).toUpperCase() + thought.mood.slice(1) %>
                    </span>
                </div>
            </div>
            <% } %>


            <% if (thought.sourceType) { %>
            <div class="meta-card">

                <div class="meta-title">
                    Source
                </div>

                <div class="meta-value">

                    <% if (thought.sourceType === "Book") { %>
                        <i class="bi bi-book-half"></i>
                    <% } else if (thought.sourceType === "Video") { %>
                        <i class="bi bi-play-circle-fill"></i>
                    <% } else if (thought.sourceType === "Podcast") { %>
                        <i class="bi bi-mic-fill"></i>
                    <% } else if (thought.sourceType === "Article") { %>
                        <i class="bi bi-newspaper"></i>
                    <% } else if (thought.sourceType === "Course") { %>
                        <i class="bi bi-mortarboard-fill"></i>
                    <% } else if (thought.sourceType === "Movie") { %>
                        <i class="bi bi-camera-reels-fill"></i>
                    <% } else if (thought.sourceType === "Conversation") { %>
                        <i class="bi bi-chat-dots-fill"></i>
                    <% } else if (thought.sourceType === "Social Media") { %>
                        <i class="bi bi-instagram"></i>
                    <% } else { %>
                        <i class="bi bi-archive-fill"></i>
                    <% } %>

                    <% if (thought.sourceLink) { %>

                        <a class="source-link"
                            href="<%= thought.sourceLink %>"
                            target="_blank">

                            <% if (thought.sourceType === "Article") { %>
                                Article / Blog
                            <% } else if (thought.sourceType === "Movie") { %>
                                Movie / Documentary
                            <% } else { %>
                                <%= thought.sourceType %>
                            <% } %>
                            -
                            <%= thought.sourceTitle %>

                            <!-- <i class="bi bi-box-arrow-up-right ms-1"></i> -->

                        </a>

                    <% } else { %>

                        <span>
                            <% if (thought.sourceType === "Article") { %>
                                Article / Blog
                            <% } else if (thought.sourceType === "Movie") { %>
                                Movie / Documentary
                            <% } else { %>
                                <%= thought.sourceType %>
                            <% } %>
                            -
                            <%= thought.sourceTitle %>
                        </span>

                    <% } %>

                </div>

            </div>
            <% } %>


            <% if (thought.dateWatched) { %>
            <div class="meta-card">
                <div class="meta-title">
                    Watched
                </div>

                <div class="meta-value">

                    <i class="bi bi-calendar-event"></i>

                    <span>
                        <%= thought.watched %>
                    </span>

                </div>
            </div>
            <% } %>
        </div>

        <hr class="thought-divider">

        <div class="reflection-footer">

            <span>
                Created <%= thought.createdDisplay %>
            </span>

            <span class="footer-separator">•</span>

            <span>
                Updated <%= thought.updatedDisplay %>
            </span>

            <span class="footer-separator">•</span>

            <span>
                <%= thought.readingTime %> min read
            </span>

        </div>

    </div>

</div>
