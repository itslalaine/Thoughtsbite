<style>
.thought-card {
  border: 2px solid #2e2e3a;
  border-radius: 18px;
  padding: 20px;
  background: #fff;
  max-width: 720px;
}

/* Header */
.thought-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.thought-meta {
  display: flex;
  gap: 12px;
}

.theme-indicator {
  width: 4px;
  border-radius: 4px;
  background: #ff7a00; /* theme color later */
}

.thought-theme {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 600;
}

.thought-date {
  font-size: 0.85rem;
  color: #777;
}

/* Content */
.thought-content {
  margin: 16px 0 20px;
  color: #444;
  line-height: 1.6;
}

/* Footer */
.thought-footer {
  display: flex;
  gap: 20px;
  color: #555;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

/* Three dots button */
.icon-btn {
  background: transparent;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  color: #555;
}

.icon-btn:focus {
  outline: 2px solid #4caf50;
  border-radius: 8px;
}

/* Dropdown */
.dropdown {
  position: relative;
}

.dropdown-menu {
  position: absolute;
  top: 36px;
  right: 0;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.12);
  padding: 8px;
  min-width: 140px;

  opacity: 0;
  transform: translateY(-6px);
  pointer-events: none;
  transition: all 0.2s ease;
}

.dropdown.open .dropdown-menu {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.dropdown-menu a,
.dropdown-menu button {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  width: 100%;
  border-radius: 8px;
  text-decoration: none;
  color: #333;
  background: none;
  border: none;
  cursor: pointer;
}

.dropdown-menu a:hover,
.dropdown-menu button:hover {
  background: #f4f4f6;
}

.dropdown-menu .danger {
  color: #d32f2f;
}

.btn-icon {
  border: none;
  background: transparent;
  padding: 6px 8px;
  line-height: 1;
}

.btn-icon i {
  font-size: 1.3rem; /* makes dots bigger */
  color: #6c757d;
  transition: color 0.2s ease, transform 0.2s ease;
}

.btn-icon:hover i {
  color: #212529;
  transform: scale(1.1);
}

/* Remove Bootstrap caret */
.dropdown-toggle::after {
  display: none;
}

</style>

<div class="container my-5" style="max-width: 720px;">
