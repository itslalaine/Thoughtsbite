<div class="container my-5" style="max-width: 720px;">

  <div class="thought-outline mx-auto">
    <!-- Page Title -->
    <div class="text-center mb-5">
      <h2 class="add-title fw-bold">Edit Thought</h2>
      <p class="text-muted">Refine or update your reflection</p>
    </div>

    <form method="POST" action="/thoughts/edit/<%= thought._id %>" class="my-3">

      <!-- Thought Content -->
      <div class="mb-4">
        <label class="form-label fw-semibold">What stood out to you?</label>
        <textarea
          class="form-control"
          rows="5"
          name="content"
          required
        ><%= thought.content %></textarea>
      </div>

      <!-- Source -->
      <div class="mb-3">
        <label class="form-label fw-semibold">Source</label>
        <input
          type="text"
          class="form-control"
          name="source"
          value="<%= thought.source || '' %>">
      </div>

      <!-- Source Link -->
      <div class="mb-4">
        <label class="form-label fw-semibold">
          Source Link <span class="text-muted">(optional)</span>
        </label>
        <input
          type="url"
          class="form-control"
          name="sourceLink"
          value="<%= thought.sourceLink || '' %>">
      </div>

      <!-- Theme / Mood / Impact -->
      <div class="row g-3 mb-4">

        <!-- Theme -->
        <div class="col-md-4">
          <label class="form-label fw-semibold">Theme</label>
          <select class="form-select" name="theme">
            <option value="">Select</option>
            <% ['Mindset','Growth','Productivity','Discipline','Life'].forEach(t => { %>
              <option value="<%= t %>" <%= thought.theme === t ? 'selected' : '' %>>
                <%= t %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Mood -->
        <div class="col-md-4">
          <label class="form-label fw-semibold">Mood</label>
          <select class="form-select" name="mood">
            <option value="">Select</option>
            <option value="motivated" <%= thought.mood === 'motivated' ? 'selected' : '' %>>😊 Motivated</option>
            <option value="neutral" <%= thought.mood === 'neutral' ? 'selected' : '' %>>😐 Neutral</option>
            <option value="confused" <%= thought.mood === 'confused' ? 'selected' : '' %>>😔 Confused</option>
            <option value="inspired" <%= thought.mood === 'inspired' ? 'selected' : '' %>>🔥 Inspired</option>
            <option value="overwhelmed" <%= thought.mood === 'overwhelmed' ? 'selected' : '' %>>😰 Overwhelmed</option>
          </select>
        </div>

        <!-- Impact -->
        <div class="col-md-4">
          <label class="form-label fw-semibold">Impact</label>
          <select class="form-select" name="impact">
            <option value="">Select</option>
            <option value="low" <%= thought.impact === 'low' ? 'selected' : '' %>>⭐ Low</option>
            <option value="medium" <%= thought.impact === 'medium' ? 'selected' : '' %>>⭐⭐ Medium</option>
            <option value="high" <%= thought.impact === 'high' ? 'selected' : '' %>>⭐⭐⭐ High</option>
          </select>
        </div>

      </div>

      <!-- Date Watched -->
      <div class="mb-5">
        <label class="form-label fw-semibold">Date Watched</label>
        <input
          type="date"
          class="form-control"
          name="dateWatched"
          value="<%= thought.dateWatched?.toISOString().split('T')[0] %>">
      </div>

      <!-- Submit Buttons -->
      <div class="d-grid gap-2 mt-4">
        <button type="submit" class="submit-thought btn">
          Update Thought
        </button>
        <a href="/thoughts" class="cancel-thought btn btn-outline-secondary mt-2">
          Cancel
        </a>
      </div>

    </form>
  </div>
</div>
