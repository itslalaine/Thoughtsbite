<style>
.thought-list-wrapper {
  padding-top: 40px; /* adjust based on navbar height */
}

.thought-list {
  max-width: 720px;   /* sweet spot for reading */
}

  .thought-item {
  transition: background 0.2s ease, box-shadow 0.2s ease;
}

.thought-item:hover {
  background: #fafafa;
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
}

/* Limit snippet to 2 lines */
.thought-snippet {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Hide actions until hover (clean list look) */
.thought-actions {
  opacity: 0;
  transition: opacity 0.2s ease;
}

.thought-item:hover .thought-actions {
  opacity: 1;
}

.tooltip-inner {
  background-color: #2f2f2f; /* or your brand dark */
  color: #fff;
  font-size: 0.75rem;
  border-radius: 8px;
  padding: 6px 10px;
}

.tooltip.bs-tooltip-top .tooltip-arrow::before {
  border-top-color: #2f2f2f;
}

.meta-click {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
}

.meta-click {
  color: #495057; /* neutral */
  text-decoration: none;
  padding-left: 10px;
  border-left: 3px solid transparent;
  transition: all 0.2s ease;
}

/* Hover reveals theme color */
.meta-click:hover {
  font-weight: 500;
}

/* Theme accents */
.meta-click.theme-life:hover {
  color: #28a745;
  border-left-color: #28a745;
}

.meta-click.theme-mindset:hover {
  color: #6f42c1;
  border-left-color: #6f42c1;
}

.meta-click.theme-growth:hover {
  color: #fd7e14;
  border-left-color: #fd7e14;
}

</style>
<div class="thought-list-wrapper">
  <div class="thought-list mx-auto">
    <% if (thoughts.length === 0) { %>
      <div class="container my-5" style="max-width: 720px;">
        <div class="card border-0 shadow-sm text-center">
          <div class="card-body py-5">

            <h4 class="fw-bold mb-2">Nothing here yet ✨</h4>
            <p class="text-muted mb-4">
              Thoughts you save will appear here.
            </p>

            <a href="/thoughts/add" class="btn btn-primary">
              Capture a thought
            </a>

          </div>
        </div>
      </div>
    <% } else { %>
    <% thoughts.forEach(thought => { %>
      <div class="thought-item border rounded-4 p-3 mb-3 shadow-sm">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-1">
          <h6 class="fw-semibold mb-0">
            <a
              href="/thoughts/<%= thought._id %>"
              class="meta-click theme-<%= thought.theme.toLowerCase() %>"
            >
              <%= thought.theme %>
            </a>
          </h6>
          <small class="text-muted">
            <%= new Date(thought.dateWatched || thought.createdAt).toLocaleDateString() %>
          </small>
        </div>

        <!-- Snippet -->
        <p class="text-muted mt-3 mb-2 thought-snippet">
          <%= thought.content %>
        </p>

        <!-- Tags -->
        <div class="d-flex flex-wrap gap-2 mt-4 mb-2">
          <% if (thought.mood) { %>
            <% if (thought.mood === 'motivated') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-emoji-smile"></i> 
            </span>
            <% } %>
            <% if (thought.mood === 'neutral') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-emoji-neutral"></i>
            </span>
            <% } %>
            <% if (thought.mood === 'confused') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-question-circle"></i>
            </span>
            <% } %>
            <% if (thought.mood === 'inspired') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-lightbulb"></i>
            </span>
            <% } %>
            <% if (thought.mood === 'overwhelmed') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-exclamation-circle "></i>
            </span>
            <% } %>
          <% } %>

          <% if (thought.impact) { %>
            <% if (thought.impact === 'high') { %>
              <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.impact %>">
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>     
              </span>
            <% } %>
            <% if (thought.impact === 'medium') { %>
              <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.impact %>">
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>   
              </span>
            <% } %>
            <% if (thought.impact === 'low') { %>
              <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.impact %>">
                <i class="bi bi-star-fill"></i>
              </span>
            <% } %>
          <% } %>
        </div>

        <!-- Actions -->
        <div class="d-flex justify-content-end gap-2 thought-actions">
          <a href="/thoughts/edit/<%= thought._id %>" class="btn btn-sm btn-outline-primary">
            Edit
          </a>
          <form
            action="/thoughts/<%= thought._id %>/delete"
            method="POST"
            onsubmit="return confirm('Delete this thought?');"
            class="d-inline"
          >
            <button class="btn btn-sm btn-outline-danger">
              Remove
            </button>
          </form>
        </div>

      </div>
    <% }) %>
    <% } %>
  </div>
</div>
<script>
  const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
  const tooltipList = [...tooltipTriggerList].map(
    tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl)
  );
</script>
