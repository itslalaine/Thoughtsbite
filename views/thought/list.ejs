<style>
.thought-list-wrapper {
  /* padding-top: 40px; */
  padding-bottom: 80px;

}

.thought-list {
  max-width: 720px;   /* sweet spot for reading */
  padding-top: 40px; /* space for filter bar */
}

.thought-item {
    max-width: 720px; /* adjust size */
    margin: 0 auto 20px auto; /* center horizontally */
    padding: 20px;
    background: #fcfcff;
    border-radius: 16px;
    border: #5c5c60 3px solid;
    box-shadow: 0 3px 10px rgba(0,0,0,0.05);
  /* transition: background 0.2s ease, box-shadow 0.2s ease; */
}

.thought-item:hover {
    background: #fafafa;
    transform: translateY(-3px);
    transition: 0.25s ease;
    box-shadow: 0 8px 16px rgba(0,0,0,0.06);
    transform: translateY(-3px);
    transition: 0.25s ease;
    box-shadow: 0 8px 16px rgba(0,0,0,0.06);
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
}

/* Limit snippet to 2 lines */
.thought-snippet {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Hide actions until hover (clean list look) */
.thought-actions {
  opacity: 0;
  transition: opacity 0.2s ease;
}

.thought-item:hover .thought-actions {
  opacity: 1;
}

.tooltip-inner {
  background-color: #2f2f2f; /* or your brand dark */
  color: #fff;
  font-size: 0.75rem;
  border-radius: 8px;
  padding: 6px 10px;
}

.tooltip.bs-tooltip-top .tooltip-arrow::before {
  border-top-color: #2f2f2f;
}

.meta-click {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
}

.meta-click {
  color: #495057; /* neutral */
  text-decoration: none;
  padding-left: 10px;
  border-left: 3px solid transparent;
  transition: all 0.2s ease;
}

/* Hover reveals theme color */
.meta-click:hover {
  font-weight: 500;
}

/* Theme accents */
.meta-click.theme-life:hover {
  color: #28a745;
  border-left-color: #28a745;
}

.meta-click.theme-mindset:hover {
  color: #6f42c1;
  border-left-color: #6f42c1;
}

.meta-click.theme-growth:hover {
  color: #fd7e14;
  border-left-color: #fd7e14;
}

/* Three-dot button */
.btn-icon {
  border: none;
  background: transparent;
  padding: 6px 8px;
  line-height: 1;
}

.btn-icon i {
  font-size: 1.3rem; /* makes dots bigger */
  color: #6c757d;
  transition: color 0.2s ease, transform 0.2s ease;
}

.btn-icon:hover i {
  color: #212529;
  transform: scale(1.1);
}

/* Remove Bootstrap caret */
.dropdown-toggle::after {
  display: none;
}

/* Dropdown styling */
.dropdown-menu {
  border-radius: 12px;
  padding: 6px;
  opacity: 0;
  transform: translateY(-6px);
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.dropdown-item {
  border-radius: 8px;
  font-size: 0.9rem;
}

/* When dropdown is shown */
.dropdown-menu.show {
  opacity: 1;
  transform: translateY(0);
}

.thought-meta-icon {
  font-size: 1rem;
  color: #6c757d;
  transition: color 0.2s ease;
}

.thought-meta-icon:hover {
  color: #212529;
}

.thought-item:focus-within .thought-actions,
.thought-item:focus-within .dropdown-menu {
  opacity: 1;
}
</style>
<div class="thought-list-wrapper">
    <%- include('../partials/thoughtFilterBar') %>
  <div class="thought-list mx-auto">
<% if (thoughts.length === 0) { %>

  <% if (filters?.search || filters?.theme || filters?.sort) { %>
    <!-- 🔍 No results for search/filter -->
    <div class="text-center text-muted mt-5">
      <p>No thoughts matched your search.</p>
      <a href="/thoughts" class="btn btn-sm btn-outline-secondary">
        Clear filters
      </a>
    </div>

  <% } else { %>
    <!-- 🌱 First-time empty state -->
    <div class="text-center text-muted mt-5">
      <p>You haven’t added any thoughts yet.</p>
      <a href="/thoughts/add" class="btn btn-primary mt-2">
        Add your first thought
      </a>
    </div>
  <% } %>

    <% } else { %>
    <% thoughts.forEach(thought => { %>
      <div class="thought-item rounded-4 p-3 mb-3 shadow-sm">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-1">
          <div>
            <h6 class="fw-semibold mb-2">
              <a
                href="/thoughts/<%= thought._id %>"
                class="meta-click theme-<%= thought.theme.toLowerCase() %>"
              >
                <%= thought.theme %>
              </a>
            </h6>
            <small class="text-muted">
                <%= new Date(thought.dateWatched || thought.createdAt).toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric'
                }) %>
            </small>
          </div>
          <!-- Three dots menu -->
          <div class="dropdown">
            <button
              class="btn btn-icon dropdown-toggle"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <i class="bi bi-three-dots"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
              <li>
                <a class="dropdown-item" href="/thoughts/edit/<%= thought._id %>">
                  <i class="bi bi-pencil me-2"></i>Edit
                </a>
              </li>
              <li>
                <form
                  action="/thoughts/<%= thought._id %>/delete"
                  method="POST"
                  onsubmit="return confirm('Delete this thought?');"
                >
                  <button class="dropdown-item text-danger">
                    <i class="bi bi-trash me-2"></i>Remove
                  </button>
                </form>
              </li>
            </ul>
          </div>
        </div>

        <!-- Snippet -->
        <p class="text-muted mt-3 mb-2 thought-snippet">
          <%= thought.content %>
        </p>

        <!-- Tags -->
        <div class="d-flex flex-wrap gap-2 mt-4 mb-2">
          <% if (thought.mood) { %>
            <% if (thought.mood === 'motivated') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-emoji-smile thought-meta-icon"></i> 
            </span>
            <% } %>
            <% if (thought.mood === 'neutral') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-emoji-neutral thought-meta-icon"></i>
            </span>
            <% } %>
            <% if (thought.mood === 'confused') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-question-circle thought-meta-icon"></i>
            </span>
            <% } %>
            <% if (thought.mood === 'inspired') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-lightbulb thought-meta-icon"></i>
            </span>
            <% } %>
            <% if (thought.mood === 'overwhelmed') { %>
            <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.mood %>">
              <i class="bi bi-exclamation-circle thought-meta-icon"></i>
            </span>
            <% } %>
          <% } %>

          <% if (thought.impact) { %>
            <% if (thought.impact === 'high') { %>
              <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.impact %>">
                <i class="bi bi-star-fill thought-meta-icon"></i>
                <i class="bi bi-star-fill thought-meta-icon"></i>
                <i class="bi bi-star-fill thought-meta-icon"></i>
   
              </span>
            <% } %>
            <% if (thought.impact === 'medium') { %>
              <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.impact %>">
                <i class="bi bi-star-fill thought-meta-icon"></i>
                <i class="bi bi-star-fill thought-meta-icon"></i>   
              </span>
            <% } %>
            <% if (thought.impact === 'low') { %>
              <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= thought.impact %>">
                <i class="bi bi-star-fill thought-meta-icon"></i>
              </span>
            <% } %>
          <% } %>
        </div>
      </div>
    <% }) %>
    <% } %>
  </div>
</div>
<script>
  const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
  const tooltipList = [...tooltipTriggerList].map(
    tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl)
  );
</script>
