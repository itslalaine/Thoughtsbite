<style>
/* Back to top button */
.back-to-top{
    position: fixed;
    right: 24px;
    bottom: 24px;

    width: 52px;
    height: 52px;

    border: 3px solid #5c5c60;
    border-radius: 50%;

    background: #FCFCFD;
    color: #5c5c60;

    display: none;
    z-index: 1000;

    transition: all .25s ease;
    box-shadow: 0 8px 18px rgba(0,0,0,.15);
}

.back-to-top:hover{
    background: #fafafa;
    transform: translateY(-3px);
}

.back-to-top i{
    font-size: 1.2rem;
}

.tooltip{
    --bs-tooltip-bg: #2F3A34;
    --bs-tooltip-color: #fff;
    --bs-tooltip-border-radius: 10px;
    --bs-tooltip-padding-x: .8rem;
    --bs-tooltip-padding-y: .45rem;
    --bs-tooltip-font-size: .82rem;
    --bs-tooltip-opacity: 1;
}
.tooltip.bs-tooltip-left .tooltip-arrow::before,
.tooltip.bs-tooltip-end .tooltip-arrow::before{
    border-left-color:#2F3A34;
}

.tooltip.bs-tooltip-top .tooltip-arrow::before{
    border-top-color:#2F3A34;
}

.tooltip.bs-tooltip-bottom .tooltip-arrow::before{
    border-bottom-color:#2F3A34;
}
</style>
<div class="thought-list-wrapper">
    <%- include('../partials/thoughtFilterBar') %>
  <div class="thought-list mx-auto">
<% if (thoughts.length === 0) { %>

  <% if (filters?.search || filters?.theme || filters?.sort) { %>
    <!-- 🔍 No results for search/filter -->
    <div class="text-center text-muted mt-5">
      <p>No thoughts matched your search.</p>
      <a href="/thoughts" class="btn btn-sm btn-outline-secondary">
        Clear filters
      </a>
    </div>

  <% } else { %>
    <!-- 🌱 First-time empty state -->
    <div class="text-center text-muted mt-5">
      <p>You haven’t added any thoughts yet.</p>
      <a href="/thoughts/add" class="btn btn-primary mt-2">
        Add your first thought
      </a>
    </div>
  <% } %>

    <% } else { %>
    <% thoughts.forEach(thought => { %>
      <div class="thought-item rounded-4 p-3 mb-3 shadow-sm" data-href="/thoughts/<%= thought._id %>">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-1">
          <div>
            <h6 class="theme-badge mb-2">
                <span class="theme-dot theme-<%= thought.theme.toLowerCase() %>"></span>
                <%= thought.theme %>
            </h6>
          </div>
          <!-- Three dots menu -->
          <div class="dropdown">
            <small class="text-muted thought-date me-2">
              <%= thought.displayDate %>
            </small>
            <button
              class="btn btn-icon dropdown-toggle"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <i class="bi bi-three-dots"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
              <li>
                <a class="dropdown-item" href="/thoughts/edit/<%= thought._id %>">
                  <i class="bi bi-pencil me-2"></i>Edit
                </a>
              </li>
              <li>
              <form
                  action="/thoughts/<%= thought._id %>/delete"
                  method="POST"
                  class="deleteThoughtForm">
                  <button class="dropdown-item text-danger">
                    <i class="bi bi-trash me-2"></i>Remove
                  </button>
                </form>
              </li>
            </ul>
          </div>
        </div>

        <!-- Snippet -->
        <p class="thought-snippet mt-3 mb-4"><%= (thought.content || "").trim() %></p>
        <!-- Tags -->

        <hr class="thought-divider">

        <div class="thought-footer">

        <% if (thought.mood) { %>

            <div class="thought-meta">

                <% if (thought.mood === "motivated") { %>
                    <i class="bi bi-emoji-heart-eyes emoji"></i>
                <% } %>

                <% if (thought.mood === "neutral") { %>
                    <i class="bi bi-emoji-expressionless emoji"></i>
                <% } %>

                <% if (thought.mood === "confused") { %>
                    <i class="bi bi-emoji-tear emoji"></i>
                <% } %>

                <% if (thought.mood === "inspired") { %>
                    <i class="bi bi-emoji-laughing emoji"></i>
                <% } %>

                <% if (thought.mood === "overwhelmed") { %>
                    <i class="bi bi-emoji-dizzy emoji"></i>
                <% } %>

                <span><%= thought.mood.charAt(0).toUpperCase() + thought.mood.slice(1) %></span>

            </div>

        <% } %>

        <% if (thought.sourceType) { %>

          <div class="thought-meta">

              <% if (thought.sourceType === "Book") { %>
                  <i class="bi bi-book-half"></i>

              <% } else if (thought.sourceType === "Video") { %>
                  <i class="bi bi-play-circle-fill"></i>

              <% } else if (thought.sourceType === "Podcast") { %>
                  <i class="bi bi-mic-fill"></i>

              <% } else if (thought.sourceType === "Article") { %>
                  <i class="bi bi-newspaper"></i>

              <% } else if (thought.sourceType === "Course") { %>
                  <i class="bi bi-mortarboard-fill"></i>

              <% } else if (thought.sourceType === "Movie") { %>
                  <i class="bi bi-camera-reels-fill"></i>

              <% } else if (thought.sourceType === "Conversation") { %>
                  <i class="bi bi-chat-dots-fill"></i>

              <% } else if (thought.sourceType === "Social Media") { %>
                  <i class="bi bi-instagram"></i>

              <% } else { %>
                  <i class="bi bi-archive-fill"></i>
              <% } %>

              <span>
                  <% if (thought.sourceType === "Article") { %>
                      Article / Blog
                  <% } else if (thought.sourceType === "Movie") { %>
                      Movie / Documentary
                  <% } else { %>
                      <%= thought.sourceType %>
                  <% } %>
              </span>

          </div>

        <% } %>

        </div>
      </div>
    <% }) %>
    <% } %>
  </div>
</div>
<!-- Back to Top -->
<button id="backToTop" class="back-to-top me-md-3" data-bs-toggle="tooltip" data-bs-placement="left" title="Back to top">
    <i class="bi bi-chevron-up"></i>
</button>

<script>
  const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');

  tooltipTriggerList.forEach(el => {
      new bootstrap.Tooltip(el);
  });

</script>
