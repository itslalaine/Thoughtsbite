<div class="container add-thought-page py-5" style="min-height: 100vh; max-width: 900px;">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="card thought-card">

                <!-- Header -->

                <div class="text-center mb-3">

                    <h2 class="page-title">
                        New Thought
                    </h2>

                    <p class="page-subtitle">
                        Capture what resonated with you today
                    </p>

                </div>

                <form id="addThoughtForm" action="/thoughts/add" method="POST">

                    <!-- ========================= -->
                    <!-- Reflection -->
                    <!-- ========================= -->

                    <div class="form-section">

                        <div class="section-header">

                            <!-- <div class="section-icon">
                                <i class="bi bi-pencil"></i>
                            </div> -->

                            <div>

                                <h5 class="section-title">
                                    What stood out to you?
                                </h5>

                                <p class="section-subtitle">
                                    Capture the lesson, insight, or reminder you want to revisit.
                                </p>

                            </div>

                        </div>

                        <textarea
                            class="form-control thought-textarea <%= errors?.content ? 'is-invalid' : '' %>"
                            name="content"
                            rows="6"
                            maxlength="1000"
                            placeholder="Write your thoughts here..."
                            ><%= oldInput?.content || '' %></textarea>

                        <% if (errors?.content) { %>
                            <div class="invalid-feedback">
                                <%= errors.content %>
                            </div>
                        <% } %>

                    </div>


                    <hr class="section-divider">
                    <!-- ========================= -->
                    <!-- Source -->
                    <!-- ========================= -->

                    <div class="form-section">

                        <div class="section-header">

                            <div>

                                <h5 class="section-title">
                                    Source details
                                </h5>
                            </div>

                        </div>

                        <div class="row g-3">

                            <div class="col-md-5">

                                <label class="form-label">

                                    Source Type

                                </label>

                                <select
                                    class="form-select <%= errors?.sourceType ? 'is-invalid' : '' %>"
                                    name="sourceType"
                                    id="source">

                                    <option value="">Select source</option>

                                    <option value="Book"
                                        <%= oldInput?.sourceType === "Book" ? "selected" : "" %>>
                                        Book
                                    </option>

                                    <option value="Video"
                                        <%= oldInput?.sourceType === "Video" ? "selected" : "" %>>
                                        Video
                                    </option>

                                    <option value="Podcast"
                                        <%= oldInput?.sourceType === "Podcast" ? "selected" : "" %>>
                                        Podcast
                                    </option>

                                    <option value="Article"
                                        <%= oldInput?.sourceType === "Article" ? "selected" : "" %>>
                                        Article / Blog
                                    </option>

                                    <option value="Course"
                                        <%= oldInput?.sourceType === "Course" ? "selected" : "" %>>
                                        Course
                                    </option>

                                    <option value="Movie"
                                        <%= oldInput?.sourceType === "Movie" ? "selected" : "" %>>
                                        Movie / Documentary
                                    </option>

                                    <option value="Conversation"
                                        <%= oldInput?.sourceType === "Conversation" ? "selected" : "" %>>
                                        Conversation
                                    </option>

                                    <option value="Social Media"
                                        <%= oldInput?.sourceType === "Social Media" ? "selected" : "" %>>
                                        Social Media
                                    </option>

                                    <option value="Other"
                                        <%= oldInput?.sourceType === "Other" ? "selected" : "" %>>
                                        Other
                                    </option>

                                </select>

                                <% if(errors?.sourceType){ %>
                                    <div class="invalid-feedback">
                                        <%= errors.sourceType %>
                                    </div>
                                <% } %>

                            </div>

                            <div class="col-md-7">

                                <label class="form-label" id="sourceTitleLabel">

                                    Title / Episode / Name

                                </label>

                                <input
                                    type="text"
                                    class="form-control <%= errors?.sourceTitle ? 'is-invalid' : '' %>"
                                    name="sourceTitle"
                                    placeholder="Atomic Habits, Episode 12, etc."
                                    value="<%= oldInput?.sourceTitle || '' %>">

                                <% if(errors?.sourceTitle){ %>
                                    <div class="invalid-feedback">
                                        <%= errors.sourceTitle %>
                                    </div>
                                <% } %>

                            </div>

                        </div>

                        <div class="mt-3">

                            <label class="form-label">

                                Source Link
                                <span class="optional">(optional)</span>

                            </label>

                            <input
                                type="text"
                                class="form-control <%= errors?.sourceLink ? 'is-invalid' : '' %>"
                                name="sourceLink"
                                placeholder="https://..."
                                value="<%= oldInput?.sourceLink || '' %>">

                            <% if(errors?.sourceLink){ %>
                                <div class="invalid-feedback">
                                    <%= errors.sourceLink %>
                                </div>
                            <% } %>
                        </div>
                                <p class="section-subtitle mt-1">
                                    Add link so you can revisit the source later.
                                </p>
                    </div>


                    <hr class="section-divider">


                    <!-- ========================= -->
                    <!-- Reflection Details -->
                    <!-- ========================= -->

                    <div class="form-section">

                        <div class="section-header">

                            <div>

                                <h5 class="section-title">
                                    Reflection details
                                </h5>

                            </div>

                        </div>

                        <div class="row g-3">

                            <div class="col-md-6">

                                <label class="form-label">

                                    Theme

                                </label>

                                <select
                                    class="form-select <%= errors?.theme ? 'is-invalid' : '' %>"
                                    name="theme">

                                    <option value="">Select theme</option>

                                    <option value="Mindset"
                                        <%= oldInput?.theme === "Mindset" ? "selected" : "" %>>
                                        Mindset
                                    </option>

                                    <option value="Growth"
                                        <%= oldInput?.theme === "Growth" ? "selected" : "" %>>
                                        Growth
                                    </option>

                                    <option value="Productivity"
                                        <%= oldInput?.theme === "Productivity" ? "selected" : "" %>>
                                        Productivity
                                    </option>

                                    <option value="Discipline"
                                        <%= oldInput?.theme === "Discipline" ? "selected" : "" %>>
                                        Discipline
                                    </option>

                                    <option value="Life"
                                        <%= oldInput?.theme === "Life" ? "selected" : "" %>>
                                        Life
                                    </option>

                                    <option value="Other"
                                        <%= oldInput?.theme === "Other" ? "selected" : "" %>>
                                        Other
                                    </option>

                                </select>

                                <% if(errors?.theme){ %>
                                <div class="invalid-feedback">
                                    <%= errors.theme %>
                                </div>
                                <% } %>

                            </div>

                            <div class="col-md-6">

                                <label class="form-label">

                                    Mood

                                </label>

                                <select
                                    class="form-select <%= errors?.mood ? 'is-invalid' : '' %>"
                                    name="mood">

                                    <option value="">Select mood</option>

                                    <option value="inspired"
                                        <%= oldInput?.mood === "inspired" ? "selected" : "" %>>
                                        Inspired
                                    </option>

                                    <option value="motivated"
                                        <%= oldInput?.mood === "motivated" ? "selected" : "" %>>
                                        Motivated
                                    </option>

                                    <option value="neutral"
                                        <%= oldInput?.mood === "neutral" ? "selected" : "" %>>
                                        Neutral
                                    </option>

                                    <option value="confused"
                                        <%= oldInput?.mood === "confused" ? "selected" : "" %>>
                                        Confused
                                    </option>

                                    <option value="overwhelmed"
                                        <%= oldInput?.mood === "overwhelmed" ? "selected" : "" %>>
                                        Overwhelmed
                                    </option>

                                </select>

                                <% if(errors?.mood){ %>
                                <div class="invalid-feedback">
                                    <%= errors.mood %>
                                </div>
                                <% } %>
                            </div>

                        </div>

                        <div class="row mt-3">

                            <div class="col-md-6">

                                <label class="form-label">

                                    Date

                                </label>

                                <input
                                    type="date"
                                    class="form-control <%= errors?.dateWatched ? 'is-invalid' : '' %>"
                                    name="dateWatched"
                                    value="<%= oldInput?.dateWatched || '' %>">

                                <% if(errors?.dateWatched){ %>
                                <div class="invalid-feedback">
                                    <%= errors.dateWatched %>
                                </div>
                                <% } %>
                            </div>
                                <p class="section-subtitle mt-1">
                                    When did you encounter this reflection?
                                </p>

                        </div>

                    </div>


                    <!-- ========================= -->
                    <!-- Buttons -->
                    <!-- ========================= -->

                    <div class="mt-5">

                        <button
                            type="submit"
                            class="btn btn-success btn-save w-100"
                            id="saveBtn">

                            <span id="saveText">
                                <i class="bi bi-floppy me-2"></i>
                                Keep this thought
                            </span>

                            <span id="saveLoading" class="d-none">

                                <span
                                    class="spinner-border spinner-border-sm me-2"
                                    role="status">
                                </span>

                                Saving your reflection...

                            </span>

                        </button>

                        <a
                            href="/thoughts"
                            class="btn btn-outline-secondary w-100 mt-3">

                            <i class="bi bi-arrow-left me-2"></i>

                            Change my mind

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

<script>
const sourceType = document.getElementById("source");
const sourceLabel = document.getElementById("sourceTitleLabel");

const labels = {
    Book: "Book Title",
    Video: "Video Title",
    Podcast: "Episode Title",
    "Article": "Article Title",
    Course: "Course Name",
    "Movie": "Movie Title",
    Conversation: "Who or what was it about?",
    "Social Media": "Post / Creator",
    Other: "Title / Name"
};

sourceType.addEventListener("change", function () {

    sourceLabel.textContent =
        labels[this.value] || "Title / Episode / Name";

});

const sourceInput = document.querySelector('input[name="sourceTitle"]');

const placeholders = {
    Book: "e.g. Atomic Habits",
    Video: "e.g. How to Build Better Habits",
    Podcast: "e.g. The Diary of a CEO - Episode 302",
    Article: "e.g. The Power of Tiny Habits",
    Course: "e.g. CS50: Introduction to Computer Science",
    Movie: "e.g. The Pursuit of Happiness",
    Conversation: "e.g. Conversation with myself lol",
    "Social Media": "e.g. James Clear Instagram Post",
    Other: "Enter title"
};

sourceType.addEventListener("change", function () {

    sourceLabel.textContent =
        labels[this.value] || "Title / Episode / Name";

    sourceInput.placeholder =
        placeholders[this.value] || "Enter title";

});

const form = document.getElementById("addThoughtForm");

form.addEventListener("submit", function () {

    document.getElementById("saveBtn").disabled = true;

    document.getElementById("saveText").classList.add("d-none");
    document.getElementById("saveLoading").classList.remove("d-none");

});
</script>