<style>
.profile-wrapper{
    width:min(90%,1170px);
    margin:clamp(2rem,5vw,4.5rem) auto;
}

/* Header */

.profile-header{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:2rem;
    margin-bottom:clamp(2rem,4vw,3rem);
}

.profile-title{
    font-size:clamp(2rem,4vw,2rem);
    font-weight:700;
    margin-bottom:.35rem;
    font-family: 'Quicksand', sans-serif;
}

.profile-subtitle{
    color:#6c757d;
    font-size:clamp(.9rem,1.2vw,1rem);
}

.profile-edit{
    color:#222;
    text-decoration:none;
    font-weight:600;
    font-size:.95rem;
}

.profile-edit:hover{
    text-decoration:underline;
}

/* Divider */

.profile-divider{
    margin:2.5rem 0;
    border-color:#989595;
}

/* Account Info */

.profile-info{
    display:flex;
    flex-direction:column;
    gap: .9rem;
    margin-bottom:2.5rem;
}

.profile-row{
    display:grid;
    grid-template-columns:180px 1fr;
    align-items:center;
    gap:1rem;
}

.profile-label{
    font-size:.9rem;
    color:#8b8b8b;
    font-weight:500;
}

.profile-value{
    font-size:1rem;
    color:#222;
    word-break:break-word;
}

/* Trash */

.profile-trash{
    color:#dc3545;
    font-weight:600;
    text-decoration:none;
}

.profile-trash:hover{
    color:#b02a37;
    text-decoration:underline;
}

.profile-trash-text{
    margin-top:.35rem;
    color:#6c757d;
    font-size:.95rem;
}

/* Responsive */

@media (max-width:768px){

    .profile-header{
        flex-direction:column;
        gap:1rem;
    }

    .profile-row{
        grid-template-columns:1fr;
        gap:.35rem;
    }

    .profile-label{
        font-size:.82rem;
    }

}
</style>

<div class="profile-wrapper">

    <div class="profile-header">

        <div>

            <h1 class="profile-title">
                My Account
            </h1>

            <p class="profile-subtitle">
                Manage your account information.
            </p>

        </div>

        <a href="/profile/edit" class="profile-edit">
            Edit
        </a>

    </div>

    <hr class="profile-divider">

    <div class="profile-info">

        <div class="profile-row">

            <span class="profile-label">
                Name
            </span>

            <span class="profile-value">
                <%= user.firstName %> <%= user.lastName %>
            </span>

        </div>

        <div class="profile-row">

            <span class="profile-label">
                Email
            </span>

            <span class="profile-value">
                <%= user.email %>
            </span>

        </div>

        <div class="profile-row">

            <span class="profile-label">
                Member Since
            </span>

            <span class="profile-value">
                <%= user.joinedDisplay %>
            </span>

        </div>

        <div class="profile-row">

            <span class="profile-label">
                Account Type
            </span>

            <span class="profile-value text-capitalize">
                <%= user.accountType %>
            </span>

        </div>

    </div>

    <hr class="profile-divider">

    <a href="/profile/deleted-thoughts" class="profile-trash">
        View Trash
    </a>

    <p class="profile-trash-text">
        Restore deleted thoughts.
    </p>

</div>