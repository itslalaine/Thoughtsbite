<style>
.profile-form-wrapper{
    width:min(90%,720px);
    margin:clamp(2rem,5vw,4rem) auto;
}

.back-link{

    display:inline-flex;
    align-items:center;
    gap:.5rem;

    margin-bottom:2rem;

    color:#5f6368;
    text-decoration:none;
    font-size:.95rem;

}

.back-link:hover{

    color:#222;

}

.form-header{
    margin-bottom:2rem;
}

.form-header h1{
    font-size:clamp(1.9rem,3vw,2.3rem);
    margin-bottom:.25rem;
}

.form-header p{
    color:#6c757d;
}

.form-group{
    margin-bottom:1.3rem;
}

.form-group label{
    display:block;
    font-size:.9rem;
    font-weight:600;
    margin-bottom:.5rem;
}

.form-group input{
    width:100%;
    padding:.75rem 1rem;   /* instead of .85rem */
    border:2px solid #5c5c60;
    border-radius:10px;    /* instead of 12px */
    font-size:.95rem;
}

.form-group input:focus{
    outline:none;
    border-color:#6FC3D6;
}

.form-actions{
    margin-top:2rem;
    display:flex;
    justify-content:flex-end;
    gap:1rem;

}

.btn-secondary{
    text-decoration:none;
    padding:.8rem 1.4rem;
    border:2px solid #5c5c60;
    color:#222;
    border-radius:12px;
}

.btn-primary{
    padding:.8rem 1.5rem;
    border:none;
    border-radius:12px;
    background:#6FC3D6;
    color:white;
    font-weight:600;
    transition:.2s;
}

.btn-primary:hover{

    transform:translateY(-2px);

}
</style>
<div class="profile-form-wrapper">

    <a href="/profile" class="back-link">
        <i class="bi bi-arrow-left"></i>
        Back to Profile
    </a>

    <div class="form-header">

        <h1>Edit Profile</h1>

        <p>
            Update your account information.
        </p>

    </div>

    <form action="/profile/edit" method="POST">

        <div class="form-group">

            <label>First Name</label>

            <input
                type="text"
                name="firstName"
                value="<%= user.firstName %>"
                required>

        </div>

        <div class="form-group">

            <label>Last Name</label>

            <input
                type="text"
                name="lastName"
                value="<%= user.lastName %>"
                required>

        </div>

        <div class="form-group">

            <label>Email Address</label>

            <input
                type="email"
                name="email"
                value="<%= user.email %>"
                required>

        </div>

        <hr>

        <div class="form-actions">

            <a href="/profile" class="btn-secondary">
                Cancel
            </a>

            <button class="btn-primary">
                Save Changes
            </button>

        </div>

    </form>

</div>