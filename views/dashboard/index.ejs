<!-- HERO -->
<div class="container text-center mt-lg- mt-md-4 mt-3 pt-5">
    <h1 class="phrase">A space for your <br> thoughts</h1>
    <div class="mt-5 gap-4 d-flex justify-content-center flex-wrap">
        <span class="custom-badge streak"><i class="bi bi-lightning-fill me-1"></i>3-day streak</span>
        <span class="custom-badge mindset"><i class="bi bi-lightbulb me-1"></i>Mindset</span>
        <span class="custom-badge thoughts"><i class="bi bi-journal-text me-1"></i>5 thoughts this week</span>
    </div>

</div>

<!-- RECENT THOUGHTS -->
<div class="recenthoughts text-center mt-lg-5 mt-md-4 mt-3 pt-3">
    <h1>Recently Captured</h1>
    <p class="sub-phrase mb-5">A quick look at your latest insights</p>
    <div id="thoughtCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">

            <!-- Slide Group 1 -->
            <div class="carousel-item active">
                <div class="container">
                    <div class="row g-4">

                        <!-- CARD 1 -->
                        <div class="col-md-4">
                            <div class="custom-card square peach">
                                <h5 class="fw-bold">Mindset</h5>
                                <small class="text-muted">Today</small>
                                <p>Growth starts with doing, not waiting. Progress beats perfection.</p>
                            </div>
                        </div>

                        <!-- CARD 2 -->
                        <div class="col-md-4">
                            <div class="custom-card square mint">
                                <h5 class="fw-bold">Growth</h5>
                                <small class="text-muted">Yesterday</small>
                                <p>Small actions compound into results. Consistency wins.</p>
                            </div>
                        </div>

                        <!-- CARD 3 -->
                        <div class="col-md-4">
                            <div class="custom-card square lavender">
                                <h5 class="fw-bold">Productivity</h5>
                                <small class="text-muted">Dec 3, 2025</small>
                                <p>Focus on one task at a time. Clarity increases output.</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Slide Group 2 -->
            <div class="carousel-item">
                <div class="container">
                    <div class="row g-4 justify-content-center">

                        <!-- CARD 4 -->
                        <div class="col-md-4">
                            <div class="custom-card square softyellow">
                                <h5 class="fw-bold">Discipline</h5>
                                <small class="text-muted">Last Week</small>
                                <p>Discipline stays when motivation fades. Habits shape your future.</p>
                            </div>
                        </div>

                        <!-- CARD 5 -->
                        <div class="col-md-4">
                            <div class="custom-card square powderblue">
                                <h5 class="fw-bold">Creativity</h5>
                                <small class="text-muted">Nov 20, 2025</small>
                                <p>Give your mind space and new ideas flow naturally.</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>

    <div class="carousel-indicators custom-dots">
        <button type="button" data-bs-target="#thoughtCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#thoughtCarousel" data-bs-slide-to="1"></button>
    </div>  
</div>

</div>
<div class="text-center m-3 pt-4 pb-5">
    <button class="btn btn-activity" type="button">View more thoughts</button>
</div>

