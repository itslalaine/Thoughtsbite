<div class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
     <div class="container">
      <div class="row d-flex justify-content-center align-items-center h-100">
        <div class="col-lg-8 col-xl-6">
          <div class="card rounded-3">
            <div class="card-body p-4 p-md-5">

              <h3 class="mb-4 pb-2 pb-md-0 mb-md-5 px-md-2">Register User</h3>
              <% if (errorMessages && errorMessages.length > 0) { %>
                <div class="alert alert-danger">
                  <ul class="mb-0">
                    <% errorMessages.forEach(error => { %>
                      <li><%= error %></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>

              <form class="px-md-2" action="/users/add" method="POST">

                <div class="row mb-3">
                  <div class="col-md-6 mb-3">
                    <label class="form-label">First Name</label>
                    <input
                    type="text"
                    name="firstName"
                    class="form-control <%= errors?.firstName ? 'is-invalid' : '' %>"
                    value="<%= oldInput?.firstName || '' %>"
                    placeholder="Juan"
                    >
                    <% if (errors?.firstName) { %>
                      <div class="invalid-feedback">
                        <%= errors.firstName %>
                      </div>
                    <% } %>
                  </div>

                  <div class="col-md-6 mb-3">
                    <label class="form-label">Last Name</label>
                    <input
                    type="text"
                    name="lastName"
                    class="form-control <%= errors?.lastName ? 'is-invalid' : '' %>"
                    value="<%= oldInput?.lastName || '' %>"
                    placeholder="Dela Cruz"
                    >
                    <% if (errors?.lastName) { %>
                      <div class="invalid-feedback">
                        <%= errors.lastName %>
                      </div>
                    <% } %>
                  </div>
                </div>

                <div class="mb-3">
                  <label class="form-label">Email</label>
                  <input
                    type="email"
                    name="email"
                    class="form-control <%= errors?.email ? 'is-invalid' : '' %>"
                    value="<%= oldInput?.email || '' %>"
                    placeholder="juan@gmail.com"
                  >
                  <% if (errors?.email) { %>
                    <div class="invalid-feedback">
                      <%= errors.email %>
                    </div>
                  <% } %>
                </div>

                <div class="mb-3">
                  <label class="form-label">Password</label>
                  <input
                    type="password"
                    name="password"
                    class="form-control <%= errors?.password ? 'is-invalid' : '' %>"
                  >

                  <% if (errors?.password) { %>
                    <div class="invalid-feedback">
                      <%= errors.password %>
                    </div>
                  <% } %>
                </div>
                <button type="submit" class="btn btn-success w-100">Create User</button>
              </form>
            </div>
          </div>
        </div>
    </div>
</div>