<style>
    .analytics-page {
    max-width: 900px;
}

/* HEADER */
.analytics-title {
    font-weight: 600;
}

.analytics-subtitle {
    color: #777;
    margin-top: 16px;
    font-size: 24px;
}

/* STATUS BAR */
.analytics-status {
    display: flex;
    justify-content: space-between;
    align-items: center;

    background: #fff;
    border: 1px solid #eee;

    padding: 12px 18px;
    border-radius: 999px;

    box-shadow: 0 4px 10px rgba(0,0,0,0.04);
}

.status-content {
    display: flex;
    gap: 10px;
    font-size: 14px;
}

.divider {
    color: #bbb;
}

.status-icon {
    color: #999;
}

/* GRID */
.analytics-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 18px;
}

/* LEFT COLUMN */
.left {
    display: flex;
    flex-direction: column;
    gap: 18px;
}

/* RIGHT COLUMN */
.right {
    display: flex;
    flex-direction: column;
    gap: 18px;
}

/* CARD BASE */
.card {
    background: #fff;
    border-radius: 18px;
    padding: 20px;
    border: 1px solid #eee;

    box-shadow: 0 6px 16px rgba(0,0,0,0.04);
}

/* CHART */
.chart-card {
    height: 250px;
}

.card-title {
    font-weight: 500;
    margin-bottom: 10px;
    color: #333;
}

/* THEME */
.theme-card {
    position: relative;
    overflow: hidden;
}

.small-label {
    font-size: 13px;
    color: #777;
    margin-bottom: 5px;
}

.theme-value {
    font-size: 28px;
    font-weight: 600;
    z-index: 2;
    position: relative;
}

.theme-bg {
    position: absolute;
    font-size: 80px;
    font-weight: 700;
    color: rgba(0,0,0,0.04);
    bottom: -10px;
    right: 10px;
}

/* MOOD */
.mood-value {
    font-size: 20px;
}

.mood-value span {
    font-size: 14px;
    color: #777;
}

/* RIGHT STATS */
.stat-card {
    text-align: left;
}

.stat-value {
    font-size: 28px;
    font-weight: 600;
}

.stat-label {
    font-size: 13px;
    color: #777;
}
</style>
<div class="container analytics-page">

    <!-- HEADER -->
    <div class="text-center mb-3">
        <!-- <h2 class="analytics-title">Thoughts this week</h2> -->
        <h2 class="analytics-subtitle">your mind, visualized</h2>
    </div>

    <!-- STATUS BAR -->
    <div class="analytics-status mb-4">
        <div class="status-content">
            <span>Thought summary for this week: You need to have the right mindset to achieve your goals. Act on them. Be desciplined. Show up no matter what. </span>
            <!-- <span>🔥day streak</span>
            <span class="divider">|</span>
            <span>🙂 calm energy today</span> -->
        </div>
        <!-- <div class="status-icon">▾</div> -->
    </div>

    <!-- MAIN GRID -->
    <div class="analytics-grid">

        <!-- LEFT -->
        <div class="left">

            <!-- CHART -->
            <div class="card chart-card">
                <div class="card-title">thoughts this week</div>
                <canvas id="thoughtChart">
                    
                </canvas>
            </div>

            <!-- THEME -->
            <div class="card theme-card">
                <div class="small-label">you’ve been thinking about</div>
                <div class="theme-value"><%= mostUsedTheme %></div>
                <!-- <div class="theme-bg"><%= mostUsedTheme %></div> -->
            </div>

            <!-- MOOD -->
            <!-- <div class="card mood-card">
                <div class="small-label">your emotional tone</div>
                <div class="mood-value">🙂 Calm <span>↗ improving</span></div>
            </div> -->

        </div>

        <!-- RIGHT -->
        <div class="right">

            <div class="card stat-card">
                <div>🔥</div>
                <div class="stat-value"><%= streak %></div>
                <div class="stat-label">days consistent</div>
            </div>

            <div class="card stat-card">
                <div>🙂</div>
                <div class="stat-value"><%= thoughtsThisMonth %></div>
                <div class="stat-label">thoughts this month</div>
            </div>

            <div class="card stat-card">
                <div>⭐</div>
                <div class="stat-value">4.2</div>
                <div class="stat-label">avg clarity</div>
            </div>

        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('thoughtChart');

new Chart(ctx, {
    type: 'line',
    data: {
        labels: ['Su','Mo','Tu','We','Th','Fr','Sa'],
        datasets: [{
            data: [1,2,2,4,6,5,4],
            borderColor: '#333',
            borderWidth: 2,
            pointBackgroundColor: '#333',
            tension: 0.4
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { display: false } },
            y: { grid: { color: '#eee' } }
        }
    }
});
</script>

