<div class="container analytics-page py-4 mb-5">

    <!-- HEADER -->
    <div class="text-center mb-4">
        <h2 class="analytics-title">Your Growth</h2>
        <p class="analytics-subtitle">
            Here's how your reflection journey looked this week. <br>
            <%= startOfWeek %> - <%= endOfWeek %>
        </p>
    </div>

    <% const thoughtsThisWeek = weeklyData.reduce((a,b)=>a+b,0); %>

    <!-- ========================= -->
    <!-- FIRST ROW -->
    <!-- ========================= -->

    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="card analytics-card chart-card">

                <div class="card-title">

                    <%= thoughtsThisWeek === 0
                    ? "No thoughts captured this week"
                    : thoughtsThisWeek === 1
                    ? "You captured 1 thought this week"
                    : `You captured ${thoughtsThisWeek} thoughts this week`
                    %>

                </div>

                    <canvas
                        id="thoughtChart"
                        data-weekly='<%- JSON.stringify(weeklyData) %>'>
                    </canvas>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4 d-flex flex-column gap-3">

            <!-- Current Streak -->

            <div class="card analytics-card stat-card streak-card mb-4 flex-fill">

                <div class="stat-wrapper">

                    <div class="stat-icon-circle streak">
                        <i class="bi bi-fire"></i>
                    </div>

                    <div class="stat-content">

                        <div class="stat-title">

                            Current streak

                        </div>

                        <div class="stat-number">

                            <%= streak %>

                            <span><%= streakLabel %></span>

                        </div>

                        <div class="stat-subtitle">

                            <%= streakMessage %>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Thoughts This Month -->
            <div class="card analytics-card stat-card month-card flex-fill">

                <div class="stat-wrapper">
                    <div class="stat-icon-circle month">
                        <i class="bi bi-journal-album"></i>
                    </div>

                    <div class="stat-content">
                        <div class="stat-title">
                            Thoughts this month
                        </div>

                        <div class="stat-number">
                            <%= thoughtsThisMonth %>
                        </div>

                        <div class="stat-subtitle positive">
                            Every reflection counts.
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- ========================= -->
    <!-- SECOND ROW -->
    <!-- ========================= -->

    <div class="row g-4 mt-1">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="card analytics-card">

                <h5 class="section-title mb-4 ">

                    How you've been feeling

                </h5>

                <!-- Inspired -->
                 <% if (thoughtsThisWeek === 0) { %>

                <div class="empty-mood-state mb-3">

                    <div class="empty-icon"><i class="bi bi-leaf"></i></div>

                    <p>No mood data yet.</p>

                    <small>
                        Capture your first reflection this week to see your emotional trends.
                    </small>

                </div>

                <% } else { %>

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-laughing emoji"></i>
                            <span>Inspired</span>
                        </div>

                        <span><%= moodsThisWeek.Inspired %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Inspired %>%;
                            background:<%= moodColors.Inspired %>">
                        </div>

                    </div>

                </div>

                <!-- Motivated -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-heart-eyes emoji"></i>
                            <span>Motivated</span>
                        </div>

                        <span><%= moodsThisWeek.Motivated %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Motivated %>%;
                            background:<%= moodColors.Motivated %>">
                        </div>

                    </div>

                </div>

                <!-- Neutral -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-expressionless emoji"></i>
                            <span>Neutral</span>
                        </div>

                        <span><%= moodsThisWeek.Neutral %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Neutral %>%;
                            background:<%= moodColors.Neutral %>">
                        </div>

                    </div>

                </div>

                <!-- Confused -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-tear emoji"></i>
                            <span>Confused</span>
                        </div>

                        <span><%= moodsThisWeek.Confused %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Confused %>%;
                            background:<%= moodColors.Confused %>">
                        </div>

                    </div>

                </div>

                <!-- Overwhelmed -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-dizzy emoji"></i>
                            <span>Overwhelmed</span>
                        </div>

                        <span><%= moodsThisWeek.Overwhelmed %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Overwhelmed %>%;
                            background:<%= moodColors.Overwhelmed %>">
                        </div>

                    </div>

                </div>

            <% } %>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">

        <div class="card analytics-card insight-card h-100">

            <div class="insight-title">
                <i class="bi bi-circle-fill me-2"></i>
                Weekly insight
            </div>

            <div class="insight-section mt-3">

                <div class="insight-label">
                    Focus Areas
                </div>

                <div class="theme-pills">

                    <span class="theme-pill">
                        <%= topThemes[0] || "No Theme" %>
                    </span>

                    <% if(topThemes[1]) { %>
                        <span class="theme-pill">
                            <%= topThemes[1] %>
                        </span>
                    <% } %>

                </div>
            </div>

            <!-- <div class="insight-section mt-4">

                <div class="insight-label">
                    Dominant Mood
                </div>

                <span class="">
                </span>

            </div> -->

            <br> 
            <span class="border" style="border-top:1px solid #7e7e7e;"></span>
            <div class="insight-section mt-3">

                <div class="insight-label">
                    Reflection
                </div>

                <p class="reflection-text">
                    <%= weeklyReflectionMessage %>
                </p>
                <br>                
                <p class="reflection-text"> Every reflection shapes your growth. </p>

            </div>

        </div>

        </div>

    </div>

</div>
