<style>
.analytics-page {
    max-width: 1170px;
}

.analytics-title {
    color: #777;
    margin-top: 16px;
    font-size: 24px;
}

.analytics-subtitle {
    color: #777;
    font-size: 16px;
}

.card {
    background: #fff;
    border-radius: 18px;
    padding: 20px;
    border: 1px solid #eee;
    box-shadow: 0 6px 16px rgba(0,0,0,0.04);
}
.analytics-card {
    border-radius: 20px;
    border: 1px solid #ececec;
    padding: 20px;
    box-shadow: 0 2px 10px rgba(0,0,0,.03);
}

.chart-card {
    min-height: 300px;
}

.chart-card canvas {
    height: 300px !important;
}

.stat-card {
    /* text-align: center; */
    margin-bottom: 15px;
}

.stat-icon {
    font-size: 1.5rem;
    margin-bottom: 10px;
}

.stat-value {
    font-size: 2rem;
    font-weight: 700;
}

.stat-label {
    color: #777;
}

.insight-card {
    background: #fafdf9;
}

.insight-title {
    font-weight: 600;
    margin-bottom: 10px;
}

.analytics-card {
    border-radius: 18px;
    border: 1px solid #ececec;
    padding: 20px;
    box-shadow: 0 2px 10px rgba(0,0,0,.03);
}

.section-title {
    font-weight: 600;
    margin-bottom: 20px;
}

.insight-item {
    margin-bottom: 18px;
}

.insight-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: .95rem;
}

.progress {
    height: 10px;
    background: #f3f4f6;
    border-radius: 999px;
}

.progress-bar {
    background: #4CAF50;
    border-radius: 999px;
}

.analytics-card {
    border-radius: 20px;
    border: 1px solid #e9ecef;
    padding: 24px;
}

.stat-card {
    margin-bottom: 20px;
}

.stat-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 16px;
}

.stat-icon-circle {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255,255,255,.6);

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 1.5rem;
    flex-shrink: 0;
}

.stat-content {
    flex: 1;
}

.stat-title {
    font-size: .95rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 8px;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    color: #1f2937;
}

.stat-number span {
    font-size: 1.2rem;
    font-weight: 400;
    color: #666;
}

.stat-subtitle {
    margin-top: 10px;
    font-size: .9rem;
    color: #666;
}

.positive {
    color: #2e7d32;
    font-weight: 500;
}

/* Card Colors */

.streak-card {
    background: #f8f3ef;
}

.month-card {
    background: #f3f6ff;
}

.insight-card{
    background:#fffef9;
    border:1px solid #f1e5c6;
}

.insight-item{
    margin-right: 15px;
    margin-left: 8px;
}

.insight-text{
    margin-top:15px;
    font-size:15px;
    line-height:1.7;
    color:#555;
}

.insight-footer{
    margin-top:20px;
    color:#4CAF50;
    font-weight:600;
    font-size:14px;
}

.insight-card,
.streak-card,
.month-card{
    min-height: 170px;
}

.stat-wrapper{
    height:100%;
    display:flex;
    align-items:center;
}

.insight-card{
    padding:24px;
}

.insight-title, .card-title, .section-title{
    font-size:16px;
    font-weight:600;
    color:#333;
}

.insight-label{
    font-size:13px;
    font-weight:600;
    color:#888;
    margin-bottom:10px;
}

.theme-pills{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
}

.theme-pill{
    background:#E8F5E9;
    color:#2E7D32;
    padding:7px 14px;
    border-radius:30px;
    font-size:13px;
    font-weight:600;
}

.reflection-text{
    color:#555;
    line-height:1.8;
    margin:0;
    font-size:14px;
}

.mood-name{
    display:flex;
    align-items:center;
    gap:8px;
}

.emoji{
    font-size:18px;
}
</style>

<div class="container analytics-page py-4 mb-5">

    <!-- HEADER -->
    <div class="text-center mb-4">
        <h2 class="analytics-title">Your Growth</h2>
        <p class="analytics-subtitle">
            <%= startOfWeek %> - <%= endOfWeek %>
        </p>
    </div>

    <% const thoughtsThisWeek = weeklyData.reduce((a,b)=>a+b,0); %>

    <!-- ========================= -->
    <!-- FIRST ROW -->
    <!-- ========================= -->

    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="card analytics-card chart-card">

                <div class="card-title">

                    <%= thoughtsThisWeek === 0
                    ? "No reflections captured this week"
                    : thoughtsThisWeek === 1
                    ? "You captured 1 reflection this week"
                    : `You captured ${thoughtsThisWeek} reflections this week`
                    %>

                </div>

                <canvas id="thoughtChart"></canvas>

            </div>

        </div>

        <!-- RIGHT -->
                 <!-- RIGHT -->
        <div class="col-lg-4 d-flex flex-column">

            <!-- Current Streak -->

            <div class="card analytics-card stat-card streak-card mb-4 flex-fill">

                <div class="stat-wrapper">

                    <div class="stat-icon-circle">

                        🔥

                    </div>

                    <div class="stat-content">

                        <div class="stat-title">

                            Current streak

                        </div>

                        <div class="stat-number">

                            <%= streak %>

                            <span><%= streakLabel %></span>

                        </div>

                        <div class="stat-subtitle">

                            <%= streakMessage %>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Thoughts This Month -->
            <div class="card analytics-card stat-card month-card flex-fill">

                <div class="stat-wrapper">
                    <div class="stat-icon-circle">
                        📝
                    </div>

                    <div class="stat-content">
                        <div class="stat-title">
                            Thoughts this month
                        </div>

                        <div class="stat-number">
                            <%= thoughtsThisMonth %>
                        </div>

                        <div class="stat-subtitle positive">
                            Every reflection counts.
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- ========================= -->
    <!-- SECOND ROW -->
    <!-- ========================= -->

    <div class="row g-4 mt-1">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="card analytics-card">

                <h5 class="section-title mb-4 ">

                    How you've been feeling?

                </h5>

                <!-- Inspired -->
                 <% if (thoughtsThisWeek === 0) { %>

                <div class="empty-mood-state mb-3">

                    <div class="empty-icon">🌱</div>

                    <p>No mood data yet.</p>

                    <small>
                        Capture your first reflection this week to see your emotional trends.
                    </small>

                </div>

                <% } else { %>

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <span class="emoji">😊</span>
                            <span>Inspired</span>
                        </div>

                        <span><%= moodsThisWeek.Inspired %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Inspired %>%;
                            background:<%= moodColors.Inspired %>">
                        </div>

                    </div>

                </div>

                <!-- Motivated -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <span class="emoji">💪</span>
                            <span>Motivated</span>
                        </div>

                        <span><%= moodsThisWeek.Motivated %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Motivated %>%;
                            background:<%= moodColors.Motivated %>">
                        </div>

                    </div>

                </div>

                <!-- Neutral -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <span class="emoji">😐</span>
                            <span>Neutral</span>
                        </div>

                        <span><%= moodsThisWeek.Neutral %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Neutral %>%;
                            background:<%= moodColors.Neutral %>">
                        </div>

                    </div>

                </div>

                <!-- Overwhelmed -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <span class="emoji">😵</span>
                            <span>Overwhelmed</span>
                        </div>

                        <span><%= moodsThisWeek.Overwhelmed %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Overwhelmed %>%;
                            background:<%= moodColors.Overwhelmed %>">
                        </div>

                    </div>

                </div>

                <!-- Confused -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <span class="emoji">🤔</span>
                            <span>Confused</span>
                        </div>

                        <span><%= moodsThisWeek.Confused %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Confused %>%;
                            background:<%= moodColors.Confused %>">
                        </div>

                    </div>

                </div>
            <% } %>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">

        <div class="card analytics-card insight-card h-100">

            <div class="insight-title">
                💡 Weekly insight
            </div>

            <div class="insight-section mt-3">

                <div class="insight-label">
                    Focus Areas
                </div>

                <div class="theme-pills">

                    <span class="theme-pill">
                        <%= topThemes[0] || "No Theme" %>
                    </span>

                    <% if(topThemes[1]) { %>
                        <span class="theme-pill">
                            <%= topThemes[1] %>
                        </span>
                    <% } %>

                </div>
            </div>

            <!-- <div class="insight-section mt-4">

                <div class="insight-label">
                    Dominant Mood
                </div>

                <span class="">
                </span>

            </div> -->

            <br>
            <div class="insight-section mt-4">

                <div class="insight-label">
                    Reflection
                </div>

                <p class="reflection-text">
                    <%= weeklyReflectionMessage %>
                </p>
                <br>                
                <p class="reflection-text">🌱 Every reflection shapes your growth. </p>

            </div>

        </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const ctx = document.getElementById('thoughtChart');
const maxValue = Math.max(...<%- JSON.stringify(weeklyData) %>);

new Chart(ctx, {
    type: 'line',
    data: {
        labels: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
        datasets: [{
            data: <%- JSON.stringify(weeklyData) %>,
            borderColor: '#43A047',

            backgroundColor: 'rgba(67,160,71,0.12)',

            fill: true,

            borderWidth: 3,

            tension: 0.4,

            pointRadius: 5,

            pointHoverRadius: 7,

            pointBackgroundColor: '#43A047',

            pointBorderColor: '#fff',

            pointBorderWidth: 2
        }]
    },
    options: {
        interaction: {
            mode: 'index',
            intersect: false
        },
        plugins: {
            legend: {
                display: false
            },
            tooltip: {
                displayColors: false,
                callbacks: {
                    label: function(context) {
                        const value = context.raw;

                        return value === 1
                            ? '1 reflection'
                            : `${value} reflections`;
                    }
                }
            }
        },
        scales: {
            x: {
                grid: {
                    display: false
                },
                ticks: {
                    color: '#7A7A7A'
                }
            },
            y: {
                beginAtZero: true,
                suggestedMax: Math.max(10, maxValue + 2),
                ticks: {
                    stepSize: 2
                },
                grid: {
                    color: '#eee'
                },
                ticks: {
                    color: '#7A7A7A',
                    stepSize: 2
                }
            }
        }
    }
});

</script>