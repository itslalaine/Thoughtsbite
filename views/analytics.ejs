<style>

/* ==========================
   Stat Cards
========================== */

.stat-card,
.insight-card,
.streak-card,
.month-card {
    min-height: 170px;
}

.stat-card {
    margin-bottom: 20px;
}

.stat-wrapper {
    display: flex;
    align-items: center;
    gap: 16px;
    height: 100%;
}

.stat-icon-circle{
    width:56px;
    height:56px;

    display:flex;
    align-items:center;
    justify-content:center;

    border-radius:50%;
    font-size:24px;
    flex-shrink:0;

    box-shadow:0 3px 10px rgba(0,0,0,.05);
}

.stat-icon-circle.streak{
    font-size:32px;
    background:#FFF3E8;
    color:#F39C12;
}

.stat-icon-circle.month{
    font-size:32px;
    background:#EAF8F4;
    color:#16A085;
}

.stat-content {
    flex: 1;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    color: #1f2937;
}

.stat-number span {
    font-size: 1.2rem;
    font-weight: 400;
    color: #666;
}

.stat-subtitle {
    margin-top: 10px;
    font-size: .9rem;
    font-weight: 500;
    /* color: #2E7D32; */
    color: #666;
}


/* ==========================
   Weekly Insight
========================== */

.insight-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    color: #888;
}

.insight-text {
    margin-top: 15px;
    font-size: 15px;
    line-height: 1.7;
    color: #555;
}

.insight-footer {
    margin-top: 20px;
    font-size: 14px;
    font-weight: 600;
    color: #4CAF50;
}

.theme-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.theme-pill {
    padding: 7px 14px;
    border-radius: 30px;

    background: #E8F5E9;
    color: #2E7D32;

    font-size: 13px;
    font-weight: 600;
}

.reflection-text {
    margin: 0;
    font-size: 14px;
    line-height: 1.8;
    color: #555;
}

/* ==========================
   Mood Section
========================== */

.insight-item {
    margin: 0 15px 18px 8px;
}

.insight-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: .95rem;
}

.mood-name {
    display: flex;
    align-items: center;
    gap: 8px;
}

.emoji {
    font-size: 18px;
}

.progress {
    height: 12px;
    background: #f3f4f6;
    border-radius: 999px;
}

.progress-bar {
    border-radius: 999px;
    height:10px
}

/* .analytics-subtitle {
    background:#F7F7F7;
    border-radius:30px;
    padding:6px 16px;
} */

.mood-name{
    display:flex;
    align-items:center;
    gap:10px;
}

.mood-name .emoji{
    font-size:20px;
    line-height:1;
}

</style>

<div class="container analytics-page py-4 mb-5">

    <!-- HEADER -->
    <div class="text-center mb-4">
        <h2 class="analytics-title">Your Growth</h2>
        <p class="analytics-subtitle">
            Here's how your reflection journey looked this week. <br>
            <%= startOfWeek %> - <%= endOfWeek %>
        </p>
    </div>

    <% const thoughtsThisWeek = weeklyData.reduce((a,b)=>a+b,0); %>

    <!-- ========================= -->
    <!-- FIRST ROW -->
    <!-- ========================= -->

    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="card analytics-card chart-card">

                <div class="card-title">

                    <%= thoughtsThisWeek === 0
                    ? "No reflections captured this week"
                    : thoughtsThisWeek === 1
                    ? "You captured 1 reflection this week"
                    : `You captured ${thoughtsThisWeek} reflections this week`
                    %>

                </div>

                <canvas id="thoughtChart"></canvas>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4 d-flex flex-column gap-3">

            <!-- Current Streak -->

            <div class="card analytics-card stat-card streak-card mb-4 flex-fill">

                <div class="stat-wrapper">

                    <div class="stat-icon-circle streak">
                        <i class="bi bi-fire"></i>
                    </div>

                    <div class="stat-content">

                        <div class="stat-title">

                            Current streak

                        </div>

                        <div class="stat-number">

                            <%= streak %>

                            <span><%= streakLabel %></span>

                        </div>

                        <div class="stat-subtitle">

                            <%= streakMessage %>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Thoughts This Month -->
            <div class="card analytics-card stat-card month-card flex-fill">

                <div class="stat-wrapper">
                    <div class="stat-icon-circle month">
                        <i class="bi bi-journal-album"></i>
                    </div>

                    <div class="stat-content">
                        <div class="stat-title">
                            Thoughts this month
                        </div>

                        <div class="stat-number">
                            <%= thoughtsThisMonth %>
                        </div>

                        <div class="stat-subtitle positive">
                            Every reflection counts.
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- ========================= -->
    <!-- SECOND ROW -->
    <!-- ========================= -->

    <div class="row g-4 mt-1">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="card analytics-card">

                <h5 class="section-title mb-4 ">

                    How you've been feeling

                </h5>

                <!-- Inspired -->
                 <% if (thoughtsThisWeek === 0) { %>

                <div class="empty-mood-state mb-3">

                    <div class="empty-icon"><i class="bi bi-leaf"></i></div>

                    <p>No mood data yet.</p>

                    <small>
                        Capture your first reflection this week to see your emotional trends.
                    </small>

                </div>

                <% } else { %>

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-laughing emoji"></i>
                            <span>Inspired</span>
                        </div>

                        <span><%= moodsThisWeek.Inspired %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Inspired %>%;
                            background:<%= moodColors.Inspired %>">
                        </div>

                    </div>

                </div>

                <!-- Motivated -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-heart-eyes emoji"></i>
                            <span>Motivated</span>
                        </div>

                        <span><%= moodsThisWeek.Motivated %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Motivated %>%;
                            background:<%= moodColors.Motivated %>">
                        </div>

                    </div>

                </div>

                <!-- Neutral -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-expressionless emoji"></i>
                            <span>Neutral</span>
                        </div>

                        <span><%= moodsThisWeek.Neutral %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Neutral %>%;
                            background:<%= moodColors.Neutral %>">
                        </div>

                    </div>

                </div>

                <!-- Overwhelmed -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-dizzy emoji"></i>
                            <span>Overwhelmed</span>
                        </div>

                        <span><%= moodsThisWeek.Overwhelmed %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Overwhelmed %>%;
                            background:<%= moodColors.Overwhelmed %>">
                        </div>

                    </div>

                </div>

                <!-- Confused -->

                <div class="insight-item">

                    <div class="insight-header">

                        <div class="mood-name">
                            <i class="bi bi-emoji-tear emoji"></i>
                            <span>Confused</span>
                        </div>

                        <span><%= moodsThisWeek.Confused %></span>

                    </div>

                    <div class="progress">

                        <div class="progress-bar"
                            style="width:<%= moodBars.Confused %>%;
                            background:<%= moodColors.Confused %>">
                        </div>

                    </div>

                </div>
            <% } %>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">

        <div class="card analytics-card insight-card h-100">

            <div class="insight-title">
                <i class="bi bi-circle-fill me-2"></i>
                Weekly insight
            </div>

            <div class="insight-section mt-3">

                <div class="insight-label">
                    Focus Areas
                </div>

                <div class="theme-pills">

                    <span class="theme-pill">
                        <%= topThemes[0] || "No Theme" %>
                    </span>

                    <% if(topThemes[1]) { %>
                        <span class="theme-pill">
                            <%= topThemes[1] %>
                        </span>
                    <% } %>

                </div>
            </div>

            <!-- <div class="insight-section mt-4">

                <div class="insight-label">
                    Dominant Mood
                </div>

                <span class="">
                </span>

            </div> -->

            <br> 
            <span class="border" style="border-top:1px solid #7e7e7e;"></span>
            <div class="insight-section mt-3">

                <div class="insight-label">
                    Reflection
                </div>

                <p class="reflection-text">
                    <%= weeklyReflectionMessage %>
                </p>
                <br>                
                <p class="reflection-text"> Every reflection shapes your growth. </p>

            </div>

        </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const ctx = document.getElementById('thoughtChart');
const maxValue = Math.max(...<%- JSON.stringify(weeklyData) %>);

new Chart(ctx, {
    type: 'line',
    data: {
        labels: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
        datasets: [{
            data: <%- JSON.stringify(weeklyData) %>,
            borderColor: '#16A085',

            backgroundColor: 'rgba(67,160,71,0.12)',

            fill: true,

            borderWidth: 3,

            tension: 0.4,

            pointRadius: 5,

            pointHoverRadius: 7,

            pointBackgroundColor: '#21b099',

            pointBorderColor: '#fff',

            pointBorderWidth: 2
        }]
    },
    options: {
        interaction: {
            mode: 'index',
            intersect: false
        },
        plugins: {
            legend: {
                display: false
            },
            tooltip: {
                displayColors: false,
                callbacks: {
                    label: function(context) {
                        const value = context.raw;

                        return value === 1
                            ? '1 reflection'
                            : `${value} reflections`;
                    }
                }
            }
        },
        scales: {
            x: {
                grid: {
                    display: false
                },
                ticks: {
                    color: '#5c5c60'
                }
            },
            y: {
                beginAtZero: true,
                suggestedMax: Math.max(10, maxValue + 2),
                ticks: {
                    stepSize: 2
                },
                grid: {
                    color: '#F2F2F2'
                },
                ticks: {
                    color: '#5c5c60',
                    stepSize: 2
                }
            }
        }
    }
});

</script>