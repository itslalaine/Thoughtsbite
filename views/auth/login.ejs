<style>
body {
  background-color: #eef3f4;
}

/* Card style */
.login-card {
  border-radius: 24px;
}

/* Primary brand button */
.btn-primary {
  background-color: #4db6ac;
  border-color: #4db6ac;
}

.btn-primary:hover {
  background-color: #43a89f;
  border-color: #43a89f;
}

/* Input focus */
.form-control:focus {
  border-color: #4db6ac;
  box-shadow: 0 0 0 0.15rem rgba(77, 182, 172, 0.25);
}

/* Links */
.auth-link {
  color: #4db6ac;
  font-weight: 500;
  text-decoration: none;
}

.auth-link:hover {
  text-decoration: underline;
}

</style>

<div class="containerd-flex align-items-center justify-content-center">
  <div class="row justify-content-center align-items-center">
    <div class="col-lg-8 col-xl-7">

      <div class="card login-card border-0 shadow-sm rounded-4">
        <div class="card-body p-2 p-md-2">

          <!-- Header -->
          <div class="text-center mb-4">
            <!-- <div class="fs-2 mb-2">🍪</div> -->
            <h2 class="fw-bold mb-1">ThoughtsBite</h2>
            <p class="text-muted">Log in to continue</p>
          </div>

          <form action="/auth/login" method="POST">

            <!-- Email -->
            <div class="mb-3">
              <label class="form-label fw-semibold">Email</label>
              <input
                type="email"
                class="form-control form-control-lg rounded-3"
                placeholder="Enter your email address"
                name="email"
                required
              >
            </div>

            <!-- Password -->
            <div class="mb-2">
              <label class="form-label fw-semibold">Password</label>
              <input
                type="password"
                class="form-control form-control-lg rounded-3"
                placeholder="Enter your password"
                name="password"
                required
              >
            </div>

            <!-- Forgot -->
            <div class="text-start mb-4">
              <a href="/forgot-password" class="auth-link">
                Forgot password?
              </a>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-4">
              Continue
            </button>

            <!-- Footer -->
            <p class="text-center text-muted mt-4 mb-0">
              Don’t have an account?
              <a href="/auth/register" class="auth-link">Sign up</a>
            </p>

          </form>

        </div>
      </div>

    </div>
  </div>
</div>
