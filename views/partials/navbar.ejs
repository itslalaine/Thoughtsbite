                        User
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/users">Users List</a></li>
                        <li><a class="dropdown-item" href="/users/add">Add User</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="#">Something else here</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Thoughts
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/thoughts">Thoughts List</a></li>
                        <li><a class="dropdown-item" href="/thoughts/add">Add Thought</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link" href="/activity">My Activity</a></li>
                <li class="nav-item"><a class="nav-link" href="/analytics">Analytics</a></li>
                <% } %>
