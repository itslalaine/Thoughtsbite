<style>
/* .custom-navbar {
  background: #fff;
  transition: box-shadow 0.2s ease, border-bottom 0.2s ease;
}

.custom-navbar.scrolled {
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
} */

.navbar {
  border-top: 1px solid #e5e7eb;
  border-bottom: 1px solid #e5e7eb;
}


/* Remove Bootstrap caret */
.profile-toggle::after{
    display:none;
}

.profile-toggle{
    padding:0;
}

.profile-avatar{

    width:36px;
    height:36px;
    font-size:.85rem;
    font-weight:700;
    border-radius:50%;
    background:#F3F4F6;
    border:2px solid #5C5C60;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#444;
    transition:.2s ease;

}

.profile-avatar:hover{
    background:#ECECEC;
}

.dropdown-menu{
    min-width:160px;
    border:none;
    border-radius:16px;
    padding:.45rem;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.dropdown-item{
    border-radius:10px;
    padding:.7rem .9rem;
    transition:.2s;
}

.dropdown-item:hover{
    background:#F5F5F5;
}
</style>
<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg py-3 custom-navbar"> <!-- shadow-sm -->
    <div class="container-fluid"> 
        <!-- container-lg for centering all of the content -->
        <a class="navbar-brand ms-lg-5" aria-current="page" href="/">ThoughtsBite</a>

        <!-- Hamburger button -->
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Collapsible menu -->
        <div class="collapse navbar-collapse justify-content-end me-lg-5" id="navbarNav">
            <ul class="navbar-nav gap-4 align-items-center align-items-center-lg">
                <li class="nav-item"><a class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>" aria-current="page" href="/">Overview</a></li>
                <% if (user && user.accountType === 'admin') { %>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle <%= currentPath === '/dashboard' ? 'active' : '' %>"  href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        User
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item nav-link <%= currentPath === '/users' ? 'active' : '' %>" href="/users">Users List</a></li>
                        <li><a class="dropdown-item nav-link <%= currentPath === '/users/add' ? 'active' : '' %>" href="/users/add">Add User</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item nav-link" href="#">Something else here</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle <%= currentPath === '/thoughts' ? 'active' : '' %>" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        My Thoughts
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item nav-link <%= currentPath === '/thoughts' ? 'active' : '' %>" href="/thoughts">Thoughts List</a></li>
                        <li><a class="dropdown-item nav-link <%= currentPath === '/thoughts/add' ? 'active' : '' %>" href="/thoughts/add">Add Thought</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link <%= currentPath === '/analytics' ? 'active' : '' %>" href="/analytics">Growth</a></li>
                <% } %>
                <% if (user && user.accountType === 'standard') { %>
                <li class="nav-item"><a class="btn add rounded-pill" href="/thoughts/add" role="button">Add Thought</a></li>  
                <li class="nav-item"><a class="nav-link <%= currentPath === '/thoughts' ? 'active' : '' %>" href="/thoughts">Thoughts</a></li> 
                <li class="nav-item"><a class="nav-link <%= currentPath === '/analytics' ? 'active' : '' %>" href="/analytics">Growth</a></li>
                <% } %>
                <% if (user) { %>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle profile-toggle"
                    href="#"
                    role="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                        <span class="profile-avatar">
                            <%= `${user.firstName[0]}${user.lastName[0]}`.toUpperCase() %>
                        </span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" href="/profile">
                                <i class="bi bi-person me-2"></i>
                                Profile
                            </a>
                        </li>
                        <li>
                            <form action="/auth/logout" method="POST">
                                <button type="submit" class="dropdown-item">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>  
